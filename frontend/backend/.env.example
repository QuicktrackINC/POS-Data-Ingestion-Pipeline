# Environment variables for the POS Data Ingestion backend.
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

# ── Neon PostgreSQL ──────────────────────────────────────────────────────────
# Obtain from: Neon Console → Dashboard → Connection String
DATABASE_URL="postgresql://USER:PASSWORD@EP-HOST-NAME.region.aws.neon.tech/neondb?sslmode=require"

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV="development"          # development | production
